#!/usr/bin/env python3
# Toggle "zoom mode" — scales all monitors up uniformly, preserving layout.
#
# Hyprland silently rejects scales that don't satisfy:
#   scale = k/120 where k divides 120 * gcd(width, height)
# When given an invalid scale it snaps to the nearest valid one, and warns
# about layout/scale on TTY. We avoid this by computing a scale that's valid
# for every connected monitor before issuing any keyword.

import json
import os
import subprocess
import sys
from math import gcd

STATE_FILE = "/tmp/zoom-mode.state"
ZOOM_TARGET = 1.8  # we'll pick the nearest scale valid for ALL monitors


def monitors():
    out = subprocess.check_output(["hyprctl", "monitors", "-j"])
    return [m for m in json.loads(out) if not m.get("disabled", False)]


def valid_scales(width, height):
    """All (scale, logical_w, logical_h) where Hyprland accepts the scale."""
    base = 120 * gcd(width, height)
    out = []
    for k in range(60, 1200):  # scale range ~0.5 .. 10.0
        if base % k == 0:
            out.append((k / 120, width * 120 // k, height * 120 // k))
    return out


def best_shared_scale(mons, target):
    """Pick scale closest to `target` that's valid on every monitor."""
    per_mon = [set(round(s, 6) for s, _, _ in valid_scales(m["width"], m["height"])) for m in mons]
    common = set.intersection(*per_mon) if per_mon else set()
    if not common:
        return 1.0
    return min(common, key=lambda s: abs(s - target))


def best_individual_scale(width, height, target):
    """Pick scale closest to `target` valid for this monitor only."""
    return min(valid_scales(width, height), key=lambda t: abs(t[0] - target))[0]


def logical_dims(width, height, scale):
    return width * 120 // round(scale * 120), height * 120 // round(scale * 120)


def apply_batch(specs):
    """Apply many monitor rules in one hyprctl --batch call (atomic)."""
    if not specs:
        return
    batch = " ; ".join(f"keyword monitor {s}" for s in specs)
    subprocess.run(["hyprctl", "--batch", batch], check=True, stdout=subprocess.DEVNULL)


def notify(label, detail):
    icon = "zoom-in" if label == "ON" else "zoom-out"
    subprocess.run(
        ["notify-send", "-i", icon, "-t", "1500", f"Zoom mode: {label}", detail],
        check=False,
    )


def detect_axis(mons):
    xs = [m["x"] for m in mons]
    ys = [m["y"] for m in mons]
    return "h" if (max(xs) - min(xs)) >= (max(ys) - min(ys)) else "v"


def reflow_and_apply(mons_in_order, scales_by_name, axis):
    """Build batch specs that reflow monitors edge-to-edge along axis."""
    specs = []
    cursor = 0
    for m in mons_in_order:
        scale = scales_by_name[m["name"]]
        lw, lh = logical_dims(m["width"], m["height"], scale)
        mode = f"{m['width']}x{m['height']}@{m['refreshRate']:.5f}"
        if axis == "h":
            specs.append(f"{m['name']},{mode},{cursor}x0,{scale:.6f}")
            cursor += lw
        else:
            specs.append(f"{m['name']},{mode},0x{cursor},{scale:.6f}")
            cursor += lh
    apply_batch(specs)


def enable():
    mons = monitors()
    if not mons:
        sys.exit(0)

    axis = detect_axis(mons)

    # Snapshot: scales + axis. Positions will always be reflowed.
    with open(STATE_FILE, "w") as f:
        f.write(f"#axis={axis}\n")
        for m in mons:
            f.write(f"{m['name']}|{m['scale']}\n")

    scale = best_shared_scale(mons, ZOOM_TARGET)
    mons.sort(key=lambda m: m["x"] if axis == "h" else m["y"])
    reflow_and_apply(mons, {m["name"]: scale for m in mons}, axis)

    notify("ON", f"All monitors @ {scale:.3f}x")


def disable():
    try:
        with open(STATE_FILE) as f:
            lines = [l.strip() for l in f if l.strip()]
    except FileNotFoundError:
        lines = []

    saved_scales = {}
    axis = "h"
    for line in lines:
        if line.startswith("#axis="):
            axis = line.split("=", 1)[1]
            continue
        name, scale_str = line.split("|")
        saved_scales[name] = float(scale_str)

    mons = monitors()
    if saved_scales:
        scales_by_name = {}
        for m in mons:
            target = saved_scales.get(m["name"], m["scale"])
            scales_by_name[m["name"]] = best_individual_scale(m["width"], m["height"], target)
        mons.sort(key=lambda m: m["x"] if axis == "h" else m["y"])
        reflow_and_apply(mons, scales_by_name, axis)
    else:
        # No snapshot — fall back to Hyprland defaults.
        specs = [f"{m['name']},preferred,auto,auto" for m in mons]
        apply_batch(specs)

    try:
        os.remove(STATE_FILE)
    except FileNotFoundError:
        pass

    notify("OFF", "Restored original layout")


if os.path.exists(STATE_FILE):
    disable()
else:
    enable()
