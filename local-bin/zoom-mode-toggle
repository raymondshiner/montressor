#!/usr/bin/env python3
# Toggle "zoom mode" — scales all monitors up, preserving relative layout.
#
# Hyprland requires width/scale to be an integer (otherwise it warns and snaps),
# and `hyprctl monitors -j` only reports scale to 2 decimals, so we always
# compute a "valid" scale per monitor: scale = width / round(width / desired).

import json
import os
import subprocess
import sys

STATE_FILE = "/tmp/zoom-mode.state"
ZOOM_SCALE = 1.8


def monitors():
    out = subprocess.check_output(["hyprctl", "monitors", "-j"])
    return [m for m in json.loads(out) if not m.get("disabled", False)]


def valid_scale(width, desired):
    """Snap desired scale to one that yields integer logical width."""
    logical = max(1, round(width / desired))
    return width / logical, logical


def apply(name, mode, x, y, scale):
    spec = f"{name},{mode},{int(x)}x{int(y)},{scale:.6f}"
    subprocess.run(
        ["hyprctl", "keyword", "monitor", spec],
        check=True,
        stdout=subprocess.DEVNULL,
    )


def notify(label, detail):
    icon = "zoom-in" if label == "ON" else "zoom-out"
    subprocess.run(
        ["notify-send", "-i", icon, "-t", "1500", f"Zoom mode: {label}", detail],
        check=False,
    )


def enable():
    mons = monitors()
    if not mons:
        sys.exit(0)

    # Snapshot raw mode + pos + scale before mutating anything.
    with open(STATE_FILE, "w") as f:
        for m in mons:
            mode = f"{m['width']}x{m['height']}@{m['refreshRate']}"
            f.write(f"{m['name']}|{mode}|{m['x']},{m['y']}|{m['scale']}\n")

    # Detect arrangement axis from current positions.
    xs = [m["x"] for m in mons]
    ys = [m["y"] for m in mons]
    horizontal = (max(xs) - min(xs)) >= (max(ys) - min(ys))

    # Reflow along primary axis using each monitor's own valid scale.
    mons.sort(key=lambda m: m["x"] if horizontal else m["y"])
    cursor = 0
    for m in mons:
        mode = f"{m['width']}x{m['height']}@{m['refreshRate']}"
        if horizontal:
            scale, logical = valid_scale(m["width"], ZOOM_SCALE)
            apply(m["name"], mode, cursor, 0, scale)
            cursor += logical
        else:
            scale, logical = valid_scale(m["height"], ZOOM_SCALE)
            apply(m["name"], mode, 0, cursor, scale)
            cursor += logical

    notify("ON", f"All monitors @ ~{ZOOM_SCALE}x")


def disable():
    try:
        with open(STATE_FILE) as f:
            lines = [l.strip() for l in f if l.strip()]
    except FileNotFoundError:
        lines = []

    if lines:
        for line in lines:
            name, mode, pos, scale_str = line.split("|")
            x, y = pos.split(",")
            # Resolve a valid scale near the snapshotted value (hyprctl truncates to 2dp).
            stored = float(scale_str)
            width = int(mode.split("x")[0])
            scale, _ = valid_scale(width, stored)
            apply(name, mode, x, y, scale)
    else:
        # No snapshot — fall back to Hyprland defaults.
        for m in monitors():
            subprocess.run(
                ["hyprctl", "keyword", "monitor", f"{m['name']},preferred,auto,auto"],
                check=False,
                stdout=subprocess.DEVNULL,
            )

    try:
        os.remove(STATE_FILE)
    except FileNotFoundError:
        pass

    notify("OFF", "Restored original layout")


if os.path.exists(STATE_FILE):
    disable()
else:
    enable()
