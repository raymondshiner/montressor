{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-margin-top": 48,
  "control-center-margin-bottom": 10,
  "control-center-margin-right": 10,
  "control-center-margin-left": 0,
  "fit-to-screen": false,
  "control-center-width": 340,
  "control-center-height": 600,
  "notification-window-width": 380,
  "timeout": 8,
  "timeout-low": 5,
  "timeout-critical": 0,
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "notification-icon-size": 48,
  "widgets": [
    "buttons-grid",
    "volume",
    "backlight",
    "mpris",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "buttons-grid": {
      "actions": [
        {
          "label": "󰤨 WiFi",
          "command": "nm-connection-editor",
          "type": "toggle"
        },
        {
          "label": "󰂯 Bluetooth",
          "command": "blueman-manager",
          "type": "toggle"
        }
      ]
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },
    "backlight": {
      "label": "󰃟",
      "device": "intel_backlight",
      "subsystem": "backlight"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 56,
      "image-radius": 8
    }
  }
}
