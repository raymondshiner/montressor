# Portable across Arch (sirlexicon-laptop) and macOS — OS-specific bits gated below.

# ---------- oh-my-zsh ----------
if [[ -d "$HOME/.oh-my-zsh" ]]; then
  export ZSH="$HOME/.oh-my-zsh"
elif [[ -d "/usr/share/oh-my-zsh" ]]; then
  export ZSH="/usr/share/oh-my-zsh"
fi
ZSH_THEME=""
DISABLE_MAGIC_FUNCTIONS="true"
COMPLETION_WAITING_DOTS="true"
[[ -z "${plugins[*]}" ]] && plugins=(git fzf extract)
[[ -n "$ZSH" && -f "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# ---------- PATH ----------
[[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$HOME/.local/bin:$PATH"

# ---------- history ----------
export HISTCONTROL=ignoreboth
export HISTORY_IGNORE="(\&|[bf]g|c|clear|history|exit|q|pwd|* --help)"
export PROMPT_COMMAND="history -a; $PROMPT_COMMAND"

# ---------- portable aliases ----------
if command -v nproc >/dev/null 2>&1; then
  alias make="make -j$(nproc)"
  alias ninja="ninja -j$(nproc)"
elif command -v sysctl >/dev/null 2>&1; then
  alias make="make -j$(sysctl -n hw.ncpu)"
  alias ninja="ninja -j$(sysctl -n hw.ncpu)"
fi
alias n="ninja"
alias c="clear"
alias please="sudo"
alias tb="nc termbin.com 9999"

# ---------- spaceship config (set BEFORE sourcing) ----------
SPACESHIP_PROMPT_ASYNC=true
SPACESHIP_PROMPT_ORDER=(dir git line_sep char)
SPACESHIP_CHAR_SYMBOL="❯"
SPACESHIP_CHAR_SUFFIX=" "

# ---------- OS-specific: plugins, prompt, package aliases ----------
case "$(uname -s)" in
  Linux)
    alias rmpkg="sudo pacman -Rsn"
    alias cleanch="sudo pacman -Scc"
    alias fixpacman="sudo rm /var/lib/pacman/db.lck"
    alias update="sudo pacman -Syu"
    alias apt="man pacman"
    alias jctl="journalctl -p 3 -xb"
    alias rip="expac --timefmt='%Y-%m-%d %T' '%l\t%n %v' | sort | tail -200 | nl"

    [[ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
      source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
    [[ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
      source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
    [[ -f /usr/share/zsh/plugins/zsh-history-substring-search/zsh-history-substring-search.zsh ]] && \
      source /usr/share/zsh/plugins/zsh-history-substring-search/zsh-history-substring-search.zsh
    [[ -f /usr/share/doc/pkgfile/command-not-found.zsh ]] && \
      source /usr/share/doc/pkgfile/command-not-found.zsh
    export FZF_BASE=/usr/share/fzf
    [[ -f /usr/lib/spaceship-prompt/spaceship.zsh ]] && \
      source /usr/lib/spaceship-prompt/spaceship.zsh
    ;;
  Darwin)
    BREW_PREFIX="$(brew --prefix 2>/dev/null)"
    if [[ -n "$BREW_PREFIX" ]]; then
      alias update="brew update && brew upgrade"
      [[ -f "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]] && \
        source "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
      [[ -f "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && \
        source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
      [[ -f "$BREW_PREFIX/share/zsh-history-substring-search/zsh-history-substring-search.zsh" ]] && \
        source "$BREW_PREFIX/share/zsh-history-substring-search/zsh-history-substring-search.zsh"
      export FZF_BASE="$BREW_PREFIX/opt/fzf"
      [[ -f "$BREW_PREFIX/opt/spaceship/spaceship.zsh" ]] && \
        source "$BREW_PREFIX/opt/spaceship/spaceship.zsh"
    fi
    ;;
esac

# ---------- claude wrapper ----------
claude() { ~/.local/bin/claude-wrapped "$@"; }

# ---------- last-project tracker (for resume-project hotkey) ----------
# Records the most recent project from ~/src/ that you cd into.
_track_last_project() {
  local p="$PWD" rest name=""
  if [[ "$p" == "$HOME/src/"* ]]; then
    rest="${p#$HOME/src/}"
    name="${rest%%/*}"
  fi
  [[ -z "$name" || "$name" == .* ]] && return
  [[ -d "$HOME/src/$name" ]] || return
  mkdir -p "$HOME/.cache/jarvis"
  print -r -- "$name" > "$HOME/.cache/jarvis/last-project"
}
autoload -Uz add-zsh-hook
add-zsh-hook chpwd _track_last_project
_track_last_project   # seed on shell start

# ---------- dots: auto-sync montressor repos to GitHub ----------
# Two repos:
#   ~/montressor         (public-able dotfiles)
#   ~/montressor-private (agent prompts, CLAUDE.md, memory, hooks)
#
# `dots` figures out which repo to act on:
#   - If $PWD is inside one of the two repos → use that one.
#   - Otherwise → default to ~/montressor.
# Override explicitly: `dots-private "msg"` always hits the private repo.
#
# Usage: `dots` or `dots "fix waybar padding"`.
_dots_commit() {
  local repo="$1" msg="$2"
  ( cd "$repo" || return 1
    git add -A
    if git diff --cached --quiet; then
      echo "$(basename "$repo"): clean, nothing to commit"
      return 0
    fi
    git commit -m "${msg:-update: $(date +%Y-%m-%d\ %H:%M)}"
    git push
  )
}

dots() {
  local toplevel repo=~/montressor
  toplevel="$(git rev-parse --show-toplevel 2>/dev/null)"
  case "$toplevel" in
    "$HOME/montressor"|"$HOME/montressor-private") repo="$toplevel" ;;
  esac
  _dots_commit "$repo" "$1"
}

dots-private() { _dots_commit ~/montressor-private "$1"; }

# Refresh the package snapshots in ~/montressor/packages/ for the current OS,
# then commit + push via `dots`. No-op if the lists haven't changed.
dots-sync-pkgs() {
  local pkgdir=~/montressor/packages
  mkdir -p "$pkgdir"
  case "$(uname -s)" in
    Linux)
      command -v pacman >/dev/null || { echo "dots-sync-pkgs: pacman not found"; return 1; }
      pacman -Qqen > "$pkgdir/pacman.txt"
      pacman -Qqem > "$pkgdir/aur.txt"
      echo "dots-sync-pkgs: $(wc -l < $pkgdir/pacman.txt) native, $(wc -l < $pkgdir/aur.txt) AUR"
      ;;
    Darwin)
      command -v brew >/dev/null || { echo "dots-sync-pkgs: brew not found"; return 1; }
      brew leaves > "$pkgdir/mac-brew.txt"
      brew list --cask > "$pkgdir/mac-cask.txt"
      echo "dots-sync-pkgs: $(wc -l < $pkgdir/mac-brew.txt) brew, $(wc -l < $pkgdir/mac-cask.txt) cask"
      ;;
    *) echo "dots-sync-pkgs: unsupported OS"; return 1 ;;
  esac
  dots "sync package snapshot ($(uname -s | tr '[:upper:]' '[:lower:]'))"
}
