#!/usr/bin/env bash
# SketchyBar — Andromeda palette. Jeeves will expand modules over time.

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Andromeda hex → SketchyBar 0xAARRGGBB
BG=0xff1C1E26
FG=0xffD5CED9
MUTED=0xff677691
CYAN=0xff00E8C6
GREEN=0xffA8FF60
YELLOW=0xffFFE66D
RED=0xffEE5D43
PURPLE=0xffB084EB

sketchybar --bar height=28 \
                 color=$BG \
                 position=top \
                 sticky=on \
                 padding_left=8 \
                 padding_right=8 \
                 corner_radius=0 \
                 border_width=0

sketchybar --default \
  icon.font="JetBrainsMono Nerd Font:Bold:14.0" \
  icon.color=$CYAN \
  icon.padding_left=6 \
  icon.padding_right=4 \
  label.font="JetBrainsMono Nerd Font:Bold:13.0" \
  label.color=$FG \
  label.padding_left=2 \
  label.padding_right=8 \
  background.corner_radius=6 \
  background.height=22

# --- Left: workspaces (AeroSpace) ---
for i in 1 2 3 4 5 6 7 8 9; do
  sketchybar --add item space.$i left \
             --set space.$i \
                icon=$i \
                icon.color=$MUTED \
                label.drawing=off \
                click_script="aerospace workspace $i" \
                script="$PLUGIN_DIR/aerospace.sh $i"
done
sketchybar --add event aerospace_workspace_change

# --- Right: clock ---
sketchybar --add item clock right \
           --set clock update_freq=10 \
                       icon="" \
                       script="$PLUGIN_DIR/clock.sh"

# --- Right: battery ---
sketchybar --add item battery right \
           --set battery update_freq=60 \
                          script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

sketchybar --update
