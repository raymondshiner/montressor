{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["custom/now-playing", "custom/np-prev", "custom/np-playpause", "custom/np-next", "custom/music-ws", "clock"],
    "modules-right": ["tray", "custom/drives", "swaync", "bluetooth", "pulseaudio", "battery", "network", "custom/vpn", "group/hardware"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true
    },

    "custom/music-ws": {
        "exec": "~/.config/waybar/music-ws.sh",
        "return-type": "json",
        "on-click": "hyprctl dispatch togglespecialworkspace music",
        "tooltip": true
    },

    "custom/now-playing": {
        "exec": "~/.config/waybar/now-playing.sh",
        "return-type": "json",
        "on-click": "playerctl -p spotify play-pause",
        "tooltip": true
    },

    "custom/np-prev": {
        "exec": "~/.config/waybar/np-prev.sh",
        "return-type": "json",
        "on-click": "playerctl -p spotify previous",
        "tooltip": true
    },

    "custom/np-playpause": {
        "exec": "~/.config/waybar/np-playpause.sh",
        "return-type": "json",
        "on-click": "playerctl -p spotify play-pause",
        "tooltip": true
    },

    "custom/np-next": {
        "exec": "~/.config/waybar/np-next.sh",
        "return-type": "json",
        "on-click": "playerctl -p spotify next",
        "tooltip": true
    },

    "clock": {
        "format": "{:%a %b %d   %I:%M %p}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false,
            "children-class": "hardware-child"
        },
        "modules": ["custom/hardware-toggle", "memory", "cpu"]
    },

    "custom/hardware-toggle": {
        "exec": "~/.config/waybar/hardware-status.sh",
        "return-type": "json",
        "interval": 3,
        "tooltip": false
    },

    "cpu": {
        "format": "¾░╗Ā {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "¾░Źø {percentage}%",
        "interval": 5
    },

    "battery": {
        "states": { "warning": 50, "critical": 20 },
        "format": "{icon} {capacity}%",
        "format-charging": "¾░éä {capacity}%",
        "format-plugged": "¾░Üź {capacity}%",
        "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
        "interval": 30,
        "tooltip": false,
        "on-click": "python3 ~/.config/waybar/battery-popup.py"
    },

    "network": {
        "format-wifi": "¾░ż© {signalStrength}%",
        "format-ethernet": "¾░łĆ {ipaddr}",
        "interval": 5,
        "format-disconnected": "¾░żŁ ",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}"
    },

    "swaync": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "¾░éÜ",
            "none": "¾░é£",
            "dnd-notification": "¾░éø",
            "dnd-none": "¾░¬æ"
        },
        "on-click": "swaync-client -t",
        "on-click-right": "swaync-client -d"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¾░Ø¤ ",
        "format-icons": { "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"] },
        "on-click": "python3 ~/.config/waybar/sound-popup.py",
        "scroll-step": 5
    },

    "bluetooth": {
        "format": "¾░é» 0",
        "format-connected": "¾░é▒ {num_connections}",
        "format-disabled": "¾░é▓",
        "tooltip-format": "{controller_alias} ŌĆö {controller_address}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_address}",
        "on-click": "python3 ~/.config/waybar/bluetooth-popup.py"
    },

    "custom/drives": {
        "exec": "~/.config/waybar/drives-status.sh",
        "return-type": "json",
        "interval": 3,
        "on-click": "python3 ~/.config/waybar/drives-popup.py",
        "tooltip": true
    },

    "custom/vpn": {
        "exec": "~/.config/waybar/vpn.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "bash -c 'mullvad status | grep -q Connected && mullvad disconnect || mullvad connect'",
        "tooltip": true
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    }
}
