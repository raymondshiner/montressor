{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": [
        "custom/music-ws", "custom/now-playing", "custom/np-prev", "custom/np-playpause", "custom/np-next",
        "clock",
        "custom/np-next-m", "custom/np-playpause-m", "custom/np-prev-m", "custom/now-playing-m", "custom/music-ws-m"
    ],
    "modules-right": ["tray", "custom/drives", "swaync", "bluetooth", "pulseaudio", "battery", "network", "custom/vpn", "group/hardware"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true
    },

    "custom/music-ws": {
        "exec": "~/.config/waybar/music-ws.sh",
        "return-type": "json",
        "on-click": "hyprctl dispatch togglespecialworkspace music",
        "tooltip": true
    },

    "custom/now-playing": {
        "exec": "~/.config/waybar/now-playing.sh",
        "return-type": "json",
        "on-click": "hyprctl dispatch togglespecialworkspace music",
        "tooltip": true
    },

    "custom/np-prev": {
        "exec": "~/.config/waybar/np-prev.sh",
        "return-type": "json",
        "on-click": "playerctl -p spotify previous",
        "tooltip": true
    },

    "custom/np-playpause": {
        "exec": "~/.config/waybar/np-playpause.sh",
        "return-type": "json",
        "on-click": "playerctl -p spotify play-pause",
        "tooltip": true
    },

    "custom/np-next": {
        "exec": "~/.config/waybar/np-next.sh",
        "return-type": "json",
        "on-click": "playerctl -p spotify next",
        "tooltip": true
    },

    "custom/music-ws-m":   { "exec": "~/.config/waybar/music-ws.sh",   "return-type": "json", "tooltip": false },
    "custom/now-playing-m":{ "exec": "~/.config/waybar/now-playing.sh","return-type": "json", "tooltip": false },
    "custom/np-prev-m":    { "exec": "~/.config/waybar/np-prev.sh",    "return-type": "json", "tooltip": false },
    "custom/np-playpause-m":{"exec": "~/.config/waybar/np-playpause.sh","return-type": "json", "tooltip": false },
    "custom/np-next-m":    { "exec": "~/.config/waybar/np-next.sh",    "return-type": "json", "tooltip": false },

    "clock": {
        "format": "{:%a %b %d   %I:%M %p}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false,
            "children-class": "hardware-child"
        },
        "modules": ["custom/hardware-toggle", "memory", "cpu"]
    },

    "custom/hardware-toggle": {
        "exec": "~/.config/waybar/hardware-status.sh",
        "return-type": "json",
        "interval": 3,
        "tooltip": false
    },

    "cpu": {
        "format": "󰻠 {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "󰍛 {percentage}%",
        "interval": 5
    },

    "battery": {
        "states": { "warning": 50, "critical": 20 },
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "interval": 30,
        "tooltip": false,
        "on-click": "python3 ~/.config/waybar/battery-popup.py"
    },

    "network": {
        "format-wifi": "󰤨 {signalStrength}%",
        "format-ethernet": "󰈀 {ipaddr}",
        "interval": 5,
        "format-disconnected": "󰤭 ",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}"
    },

    "swaync": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "󰂚",
            "none": "󰂜",
            "dnd-notification": "󰂛",
            "dnd-none": "󰪑"
        },
        "on-click": "swaync-client -t",
        "on-click-right": "swaync-client -d"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 ",
        "format-icons": { "default": ["󰕿", "󰖀", "󰕾"] },
        "on-click": "python3 ~/.config/waybar/sound-popup.py",
        "scroll-step": 5
    },

    "bluetooth": {
        "format": "󰂯 0",
        "format-connected": "󰂱 {num_connections}",
        "format-disabled": "󰂲",
        "tooltip-format": "{controller_alias} — {controller_address}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_address}",
        "on-click": "python3 ~/.config/waybar/bluetooth-popup.py"
    },

    "custom/drives": {
        "exec": "~/.config/waybar/drives-status.sh",
        "return-type": "json",
        "interval": 3,
        "on-click": "python3 ~/.config/waybar/drives-popup.py",
        "tooltip": true
    },

    "custom/vpn": {
        "exec": "~/.config/waybar/vpn.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "bash -c 'mullvad status | grep -q Connected && mullvad disconnect || mullvad connect'",
        "tooltip": true
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    }
}
